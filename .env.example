# =============================================================
# Project Nimbus — Environment Variables Template
# =============================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env.local
#   2. Fill in all values in .env.local
#   3. NEVER commit .env.local to git
# =============================================================

# --- LLM API ---
# Groq API key — get yours at https://console.groq.com
GROQ_API_KEY=

# Anthropic API key (optional fallback) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Database ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# For local Docker: postgresql://nimbus:nimbus@localhost:5432/nimbus_db
DATABASE_URL=

# --- Application ---
# Set to 'development' | 'production' | 'test'
NODE_ENV=development

# Next.js public base URL (used for SSR/CSR routing)
NEXT_PUBLIC_APP_URL=http://localhost:3000
